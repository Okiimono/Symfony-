{% extends 'base.html.twig' %}

{% block title %}Recherche de produits{% endblock %}

{% block body %}
    <div class="container mt-4 bg-white p-4 border rounded shadow-sm">

        {# 1. L'en-tête avec le bouton retour et le titre #}
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom position-relative">
            {# Bouton retour #}
            <a href="javascript:history.back()" class="text-secondary position-absolute" style="font-size: 1.8rem; left: 0;">
                <i class="fas fa-arrow-circle-left"></i>
            </a>

            {# Titre centré #}
            <h3 class="mx-auto mb-0 text-center">
                <i class="fas fa-store"></i>
                Recherche de "{{ recherche }}" :
                <span class="badge badge-info bg-info text-white rounded-circle px-2 py-1" style="font-size: 0.9em;">{{ articles|length }}</span> produit(s)
            </h3>
        </div>

        {# 2. La grille des produits #}
        <div class="row">
            {% for article in articles %}
                <div class="col-md-4 mb-4">
                    <a href="#" class="text-decoration-none text-dark d-block h-100 product-link"
                       data-toggle="tooltip" data-placement="bottom"
                       title="Ajouter {{ article.libelle }} à mon panier">

                        <div class="card h-100 text-center border p-2 product-card shadow-sm transition-all">

                            <img src="{{ asset(article.visuel) }}"
                                 class="card-img-top mx-auto mt-3"
                                 style="width: 150px; height: 150px; object-fit: contain;"
                                 alt="{{ article.libelle }}">

                            <div class="card-body d-flex flex-column pb-1">
                                <h5 class="card-title font-weight-bold mb-1">{{ article.libelle }}</h5>
                                <p class="card-text font-italic text-muted mb-3" style="font-size: 0.9em;">{{ article.texte }}</p>

                                <div class="mt-auto">
                                <span class="btn btn-primary font-weight-bold px-4">
                                    <i class="fas fa-cart-plus"></i> {{ article.prix|number_format(2, ',', ' ') }} €
                                </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <p class="alert alert-warning">Aucun produit ne correspond à votre recherche.</p>
                </div>
            {% endfor %}
        </div>

    </div>

    <style>
        .product-link:hover {
            text-decoration: none;
        }
        .product-link:hover .product-card {
            border-color: #007bff !important;
            box-shadow: 0 0.5rem 1rem rgba(0, 123, 255, 0.15) !important;
        }
        .transition-all {
            transition: all 0.2s ease-in-out;
        }
    </style>

{% endblock %}
